  kus3: { viewBox: "0 0 542 526", svg: `<path d="M275.928 0L542 437.296H376.937V525.986H275.928V465.627H333.822V437.296H252.522V525.986H137.964V437.296H213.104V203.25H0L92.3867 0H275.928ZM151.514 83.7637V103.473H171.223V83.7637H151.514Z" fill="black"/>` }
};

// ── Motif data ────────────────────────────────────────────────────────────────
const MOTIFS = [
  {
    key: "akrep",
    name: "AKREP",
    subtitle: "Scorpion",
    desc: "This pattern is used as a symbol of protection against scorpions and sometimes to represent a dragon. It also represents the strength and courage of confrontation. This symbol is often used with masculine connotations.",
    variants: ["akrep"]
  },
  {
    key: "ask_ve_birlesim",
    name: "AŞK VE BİRLEŞİM",
    subtitle: "Love and Union",
    desc: "Motif inherited from the East, with the known Ying-Yang, means harmony between man and woman. This pattern shows the opposites that attract each other and the love a person feels for their lover.",
    variants: ["ask_ve_birlesim"]
  },
  {
    key: "bereket",
    name: "BEREKET",
    subtitle: "Fertility",
    desc: "Union of the Elibelinde and Koçboynuzu patterns, which includes symbol variations on protections. The graphic represents multi-grain plants such as wheat, barley, pomegranate, poppy, melon, figs, grapes and mulberry — all used to indicate fertility.",
    variants: ["bereket", "bereket2"]
  },
  {
    key: "bukagi",
    name: "BUKAGI",
    subtitle: "Fetter",
    desc: "Cuff-shaped pattern that symbolizes the continuity of family union, the dedication of lovers and the hope that they should always stay together.",
    variants: ["bukagi", "bukagi2"]
  },
  {
    key: "canavar_ayagi",
    name: "CANAVAR AYAĞI",
    subtitle: "Monster's Feet",
    desc: "This pattern is used as a symbol of protection against scorpions and sometimes to represent a dragon. It also represents the strength and courage of confrontation. This symbol is often used with masculine connotations.",
    variants: ["canavar_ayagi"]
  },
  {
    key: "cengel",
    name: "ÇENGEL",
    subtitle: "Hook",
    desc: "This pattern represents protection against the evil eye. The hooked form deflects malicious gazes and guards its wearer from harm.",
    variants: ["cengel", "cengel2"]
  },
  {
    key: "elibelinde",
    name: "ELİBELİNDE",
    subtitle: "Hands on Hips",
    desc: "Figure design of a woman drawn from the mother goddess of Anatolia, used as a symbol of motherhood and fertility. The posture — hands on hips — represents feminine power and the divine feminine.",
    variants: ["elibelinde", "elibelinde2"]
  },
  {
    key: "hayat_agaci",
    name: "HAYAT AĞACI",
    subtitle: "Tree of Life",
    desc: "A theme that represents the desire for immortality or the hope of life after death. The stylization of various plants — cypress, date palm, pomegranate, fig, olive, vine, beech and oak — symbolize the eternal tree of life.",
    variants: ["hayat_agaci", "hayat_agaci2"]
  },
  {
    key: "ibrik",
    name: "İBRİK",
    subtitle: "Ewer",
    desc: "A stylized design in the form of a water container, symbolizing purity and purification. It is also used as a symbol of pregnancy and the carrying of new life.",
    variants: ["ibrik", "ibrik2"]
  },
  {
    key: "kus",
    name: "KUŞ",
    subtitle: "Bird",
    desc: "A kilim pattern loaded with various meanings: luck and bad luck; happiness, joy and love; the soul of the dead; women; desire; waiting for news; power and strength. Few symbols carry such a wealth of interpretation.",
    variants: ["kus", "kus2", "kus3"]
  },
];

// Build flat element list for the canvas world
const ELEMENTS = [];
const WORLD_W = 6000, WORLD_H = 5000;

function seededRng(seed) {
  let s = seed;
  return () => { s = (s * 16807) % 2147483647; return (s - 1) / 2147483646; };
}
const r = seededRng(42);

const ALL_VARIANTS = [];
MOTIFS.forEach((motif, mi) => {
  motif.variants.forEach(varKey => {
    const svgData = SVGS[varKey];
    if (!svgData) return;
    const [, , vw, vh] = svgData.viewBox.split(' ').map(Number);
    ALL_VARIANTS.push({ motifIdx: mi, varKey, svgInner: svgData.svg, svgViewBox: svgData.viewBox, svgW: vw, svgH: vh });
  });
});

const COPIES = 12; // repeat each variant this many times
for (let c = 0; c < COPIES; c++) {
  ALL_VARIANTS.forEach((v, vi) => {
    ELEMENTS.push({
      x: r() * (WORLD_W - 200) + 100,
      y: r() * (WORLD_H - 200) + 100,
      motifIdx: v.motifIdx,
      varKey: v.varKey,
      svgInner: v.svgInner,
      svgViewBox: v.svgViewBox,
      svgW: v.svgW, svgH: v.svgH,
      colorIdx: (v.motifIdx + c) % 5,
    });
  });
}

const COLORS = ['#cc0000','#0000cc','#006600','#996600','#660066'];
const CREAM = '#f0e8d0';
const BG = '#c8b89a';

// ── Canvas & state ────────────────────────────────────────────────────────────
const canvas = document.getElementById('canvas');
const ctx = canvas.getContext('2d');
let W, H;
let cam = { x: WORLD_W/2, y: WORLD_H/2, zoom: 0.25 };
let tgt = { x: WORLD_W/2, y: WORLD_H/2, zoom: 0.25 };
let isDragging = false, dragMoved = false;
let lastMouse = {x:0,y:0};
let mousePos = {x:0,y:0};
let hoveredIdx = -1;

// ── SVG → Image cache via data URI (works in sandboxed iframes) ──────────────
const imgCache = {};
function getSvgImage(el, color, hovered, cb) {
  const cacheKey = el.varKey + '_' + color + '_' + hovered;
  if (imgCache[cacheKey]) { cb(imgCache[cacheKey]); return; }
  const fillColor = hovered ? CREAM : color;
  const bgColor   = hovered ? color : CREAM;
  const svgStr = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="${el.svgViewBox}">
    <rect x="0" y="0" width="${el.svgW}" height="${el.svgH}" fill="${bgColor}"/>
    ${el.svgInner.replace(/fill="black"/g, `fill="${fillColor}"`)}
  </svg>`;
  const b64 = btoa(unescape(encodeURIComponent(svgStr)));
  const url = 'data:image/svg+xml;base64,' + b64;
  const img = new Image();
  img.onload = () => { imgCache[cacheKey] = img; cb(img); };
  img.onerror = () => { imgCache[cacheKey] = null; cb(null); };
  img.src = url;
}

// Pre-render all
ELEMENTS.forEach(el => {
  const col = COLORS[el.colorIdx];
  getSvgImage(el, col, false, ()=>{});
  getSvgImage(el, col, true, ()=>{});
});

// ── Resize ────────────────────────────────────────────────────────────────────
function resize() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
}
window.addEventListener('resize', resize);
resize();

function worldToScreen(wx, wy) {
  return { x: (wx - cam.x)*cam.zoom + W/2, y: (wy - cam.y)*cam.zoom + H/2 };
}
function screenToWorld(sx, sy) {
  return { x: (sx - W/2)/cam.zoom + cam.x, y: (sy - H/2)/cam.zoom + cam.y };
}

// ── Background grid (pixel-art) ───────────────────────────────────────────────
function drawBg() {
  ctx.fillStyle = BG;
  ctx.fillRect(0, 0, W, H);
  const step = 60 * cam.zoom;
  const ox = ((-cam.x*cam.zoom + W/2) % step + step) % step;
  const oy = ((-cam.y*cam.zoom + H/2) % step + step) % step;
  ctx.strokeStyle = 'rgba(0,0,0,0.07)';
  ctx.lineWidth = 1;
  for (let x = ox-step; x < W+step; x += step) {
    ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,H); ctx.stroke();
  }
  for (let y = oy-step; y < H+step; y += step) {
    ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(W,y); ctx.stroke();
  }
}

// ── Hit test ──────────────────────────────────────────────────────────────────
const BOX = 70; // half-size in world units
function hitTest(sx, sy) {
  for (let i = ELEMENTS.length-1; i >= 0; i--) {
    const el = ELEMENTS[i];
    const s = worldToScreen(el.x, el.y);
    const half = BOX * cam.zoom;
    if (Math.abs(sx - s.x) < half && Math.abs(sy - s.y) < half) return i;
  }
  return -1;
}

// ── Draw ──────────────────────────────────────────────────────────────────────
function drawElements() {
  ELEMENTS.forEach((el, i) => {
    const s = worldToScreen(el.x, el.y);
    const half = BOX * cam.zoom;
    if (s.x + half < 0 || s.x - half > W || s.y + half < 0 || s.y - half > H) return;

    const isHov = i === hoveredIdx;
    const col = COLORS[el.colorIdx];
    const cacheKey = el.varKey + '_' + col + '_' + isHov;
    const img = imgCache[cacheKey];

    const bx = s.x - half, by = s.y - half, bw = half*2, bh = half*2;

    // Border box
    ctx.fillStyle = isHov ? col : CREAM;
    ctx.fillRect(bx, by, bw, bh);
    ctx.strokeStyle = col;
    ctx.lineWidth = isHov ? 3 : 2;
    ctx.strokeRect(bx, by, bw, bh);

    // Pixel inner shadow (net.art)
    ctx.strokeStyle = 'rgba(0,0,0,0.18)';
    ctx.lineWidth = 1;
    ctx.strokeRect(bx+3, by+3, bw-6, bh-6);

    // SVG image
    if (img) {
      const pad = half * 0.12;
      ctx.drawImage(img, bx+pad, by+pad, bw-pad*2, bh-pad*2);
    }

    // Name label
    if (cam.zoom > 0.5) {
      const motif = MOTIFS[el.motifIdx];
      ctx.save();
      ctx.font = `${Math.max(9, 11*cam.zoom)}px VT323, monospace`;
      ctx.fillStyle = isHov ? CREAM : col;
      ctx.textAlign = 'center';
      // background strip
      const tw = ctx.measureText(motif.name).width;
      ctx.fillStyle = isHov ? col : 'rgba(240,232,208,0.85)';
      ctx.fillRect(s.x - tw/2 - 3, s.y + half + 2, tw + 6, 14*cam.zoom);
      ctx.fillStyle = isHov ? CREAM : col;
      ctx.fillText(motif.name, s.x, s.y + half + 13*cam.zoom);
      ctx.restore();
    }
  });
}

// ── Tooltip ───────────────────────────────────────────────────────────────────
function drawTooltip() {
  if (hoveredIdx < 0) return;
  const el = ELEMENTS[hoveredIdx];
  const motif = MOTIFS[el.motifIdx];
  const s = worldToScreen(el.x, el.y);
  const half = BOX * cam.zoom;
  const label = `► ${motif.name} — ${motif.subtitle} ◄  [CLICK]`;
  ctx.save();
  ctx.font = '15px VT323, monospace';
  const tw = ctx.measureText(label).width;
  const lx = Math.min(Math.max(mousePos.x + 16, 4), W - tw - 10);
  const ly = mousePos.y - 14;
  ctx.fillStyle = COLORS[el.colorIdx];
  ctx.fillRect(lx-4, ly-14, tw+8, 20);
  ctx.fillStyle = CREAM;
  ctx.fillText(label, lx, ly);
  ctx.restore();
}

// ── Render ────────────────────────────────────────────────────────────────────
document.getElementById('zoom-display').textContent = '1.00×';

function render() {
  cam.x += (tgt.x - cam.x) * 0.12;
  cam.y += (tgt.y - cam.y) * 0.12;
  cam.zoom += (tgt.zoom - cam.zoom) * 0.12;
  drawBg();
  drawElements();
  drawTooltip();
  document.getElementById('zoom-display').textContent = cam.zoom.toFixed(2) + '×';
  requestAnimationFrame(render);
}

// ── Panel ─────────────────────────────────────────────────────────────────────
function openPanel(motifIdx, varKey) {
  const motif = MOTIFS[motifIdx];
  const el = ELEMENTS.find(e => e.varKey === varKey);
  const col = COLORS[el ? el.colorIdx : 0];

  document.getElementById('panel-name').textContent = motif.name;
  document.getElementById('panel-subtitle').textContent = motif.subtitle;
  document.getElementById('panel-desc').textContent = motif.desc;
  document.getElementById('panel-title').textContent = 'MOTIF — ' + motif.name;

  // Inject coloured SVG
  const svgData = SVGS[varKey];
  const svgEl = document.getElementById('panel-svg-inner');
  svgEl.setAttribute('viewBox', svgData.viewBox);
  svgEl.innerHTML = svgData.svg.replace(/fill="black"/g, `fill="${col}"`);
  svgEl.style.background = CREAM;

  document.getElementById('panel').classList.add('open');
}
window.closePanel = function() {
  document.getElementById('panel').classList.remove('open');
};

// ── Input ─────────────────────────────────────────────────────────────────────
canvas.addEventListener('mousedown', e => {
  isDragging = true; dragMoved = false;
  lastMouse = {x:e.clientX, y:e.clientY};
  document.body.classList.add('dragging');
});
window.addEventListener('mousemove', e => {
  mousePos = {x:e.clientX, y:e.clientY};
  document.getElementById('cursor-fx').style.left = e.clientX+'px';
  document.getElementById('cursor-fx').style.top = e.clientY+'px';
  if (isDragging) {
    const dx = e.clientX - lastMouse.x, dy = e.clientY - lastMouse.y;
    if (Math.abs(dx)+Math.abs(dy) > 3) dragMoved = true;
    tgt.x -= dx / cam.zoom;
    tgt.y -= dy / cam.zoom;
    lastMouse = {x:e.clientX, y:e.clientY};
    hoveredIdx = -1;
  } else {
    hoveredIdx = hitTest(e.clientX, e.clientY);
    canvas.style.cursor = hoveredIdx >= 0 ? 'pointer' : '';
  }
});
window.addEventListener('mouseup', e => {
  document.body.classList.remove('dragging');
  if (!dragMoved) {
    const idx = hitTest(e.clientX, e.clientY);
    if (idx >= 0) openPanel(ELEMENTS[idx].motifIdx, ELEMENTS[idx].varKey);
  }
  isDragging = false;
});

canvas.addEventListener('wheel', e => {
  e.preventDefault();
  const f = e.deltaY > 0 ? 0.9 : 1.1;
  const wx = (e.clientX - W/2)/cam.zoom + cam.x;
  const wy = (e.clientY - H/2)/cam.zoom + cam.y;
  tgt.zoom = Math.max(0.15, Math.min(4, tgt.zoom * f));
  tgt.x = wx - (e.clientX - W/2)/tgt.zoom;
  tgt.y = wy - (e.clientY - H/2)/tgt.zoom;
}, {passive:false});

// Touch
let lt=[];
canvas.addEventListener('touchstart', e=>{
  lt=[...e.touches];
  if(e.touches.length===1){isDragging=true;dragMoved=false;lastMouse={x:e.touches[0].clientX,y:e.touches[0].clientY};}
});
canvas.addEventListener('touchmove', e=>{
  e.preventDefault();
  if(e.touches.length===1&&isDragging){
    const dx=e.touches[0].clientX-lastMouse.x,dy=e.touches[0].clientY-lastMouse.y;
    if(Math.abs(dx)+Math.abs(dy)>3)dragMoved=true;
    tgt.x-=dx/cam.zoom;tgt.y-=dy/cam.zoom;
    lastMouse={x:e.touches[0].clientX,y:e.touches[0].clientY};
  }else if(e.touches.length===2&&lt.length===2){
    const d0=Math.hypot(lt[0].clientX-lt[1].clientX,lt[0].clientY-lt[1].clientY);
    const d1=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,e.touches[0].clientY-e.touches[1].clientY);
    tgt.zoom=Math.max(0.15,Math.min(4,tgt.zoom*(d1/d0)));lt=[...e.touches];
  }
},{passive:false});
canvas.addEventListener('touchend',e=>{
  if(!dragMoved&&e.changedTouches.length===1){
    const t=e.changedTouches[0];
    const idx=hitTest(t.clientX,t.clientY);
    if(idx>=0)openPanel(ELEMENTS[idx].motifIdx,ELEMENTS[idx].varKey);
  }
  isDragging=false;
});

// Visitor counter
let count=4721;
setInterval(()=>{count+=Math.floor(Math.random()*3);document.getElementById('count').textContent=String(count).padStart(6,'0');},3000);

requestAnimationFrame(render);
</script>
