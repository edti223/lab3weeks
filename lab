<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>K I L I M . N E T</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=VT323&family=Courier+Prime:ital,wght@0,400;0,700;1,400&display=swap');
    *{margin:0;padding:0;box-sizing:border-box;}
    :root{
      --red:#cc0000; --blue:#0000cc; --yellow:#ffcc00;
      --green:#006600; --bg:#c8b89a; --cream:#f0e8d0;
    }
    body{
      background:var(--bg);overflow:hidden;
      width:100vw;height:100vh;cursor:crosshair;
      user-select:none;font-family:'VT323',monospace;
    }
    body.dragging{cursor:move;}
    canvas{display:block;}

    #hud{
      position:fixed;top:0;left:0;right:0;z-index:20;
      display:flex;justify-content:space-between;align-items:center;
      padding:3px 12px;
      background:var(--blue);border-bottom:3px solid var(--yellow);
      font-size:19px;color:var(--yellow);letter-spacing:.12em;
    }
    .blink{animation:blink 1s step-end infinite;}
    @keyframes blink{0%,100%{opacity:1}50%{opacity:0}}

    /* Panel */
    #panel{
      position:fixed;right:0;top:0;bottom:0;width:320px;
      background:var(--cream);border-left:4px solid var(--blue);
      z-index:30;transform:translateX(100%);
      transition:transform .25s steps(8);
      display:flex;flex-direction:column;
      overflow:hidden;
    }
    #panel.open{transform:translateX(0);}
    #panel-header{
      background:var(--red);border-bottom:3px solid var(--yellow);
      padding:8px 12px;display:flex;justify-content:space-between;align-items:center;
    }
    #panel-title{font-size:20px;color:var(--yellow);letter-spacing:.1em;}
    #panel-close{
      background:var(--yellow);border:2px solid var(--blue);
      color:var(--blue);font-size:16px;font-family:inherit;
      cursor:pointer;padding:2px 8px;
    }
    #panel-close:hover{background:var(--blue);color:var(--yellow);}
    #panel-svg{
      padding:20px;display:flex;justify-content:center;align-items:center;
      background:#e8dfc8;border-bottom:2px dashed var(--blue);
      min-height:200px;
    }
    #panel-svg svg{width:140px;height:140px;display:block;}
    #panel-body{padding:16px;overflow-y:auto;flex:1;}
    #panel-name{font-size:22px;color:var(--red);letter-spacing:.08em;margin-bottom:6px;}
    #panel-subtitle{font-size:13px;color:var(--blue);font-family:'Courier Prime',monospace;font-style:italic;margin-bottom:12px;border-bottom:1px solid var(--blue);padding-bottom:8px;}
    #panel-desc{font-size:13px;color:#222;font-family:'Courier Prime',monospace;line-height:1.6;}
    #panel-footer{
      border-top:2px solid var(--blue);padding:8px 12px;
      font-size:12px;color:var(--blue);
      font-family:'Courier Prime',monospace;
    }

    #marquee-wrap{
      position:fixed;bottom:0;left:0;right:0;z-index:20;
      background:var(--red);border-top:3px solid var(--yellow);
      overflow:hidden;height:26px;
    }
    #marquee{
      display:inline-block;white-space:nowrap;
      font-size:20px;color:var(--yellow);letter-spacing:.2em;
      animation:scroll 32s linear infinite;padding-left:100%;
    }
    @keyframes scroll{from{transform:translateX(0)}to{transform:translateX(-100%)}}

    #counter{
      position:fixed;bottom:32px;left:12px;z-index:20;
      font-size:13px;color:var(--blue);
      background:var(--cream);border:2px solid var(--blue);
      padding:2px 8px;line-height:1.4;
    }
    #zoom-hint{
      position:fixed;bottom:32px;right:12px;z-index:20;
      font-size:14px;color:var(--blue);
      background:var(--cream);border:2px solid var(--blue);
      padding:2px 8px;
    }
    #cursor-fx{
      position:fixed;pointer-events:none;z-index:999;
      width:14px;height:14px;border:2px solid var(--red);
      transform:translate(-50%,-50%);
    }
  </style>
</head>
